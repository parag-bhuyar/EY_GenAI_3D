# --- secrets: never commit these ---
.env
**/.env
**/.streamlit/secrets.toml
student_config.json

# --- python noise ---
__pycache__/
*.pyc
.pytest_cache/

# --- lab run artifacts -------------------------------------------------
# These are OUTPUT files that each participant generates by running the labs.
# They must not be shipped: a student finding a pre-existing results file may
# assume the lab is already done, and the autograders read these paths.
m1_3_eval_results.json
m1_4_m2_2_part1_results.json
m2_2_part2_results.json
m2_3_m2_4_results.json

# NOTE: Day{n}/submissions/*.json is deliberately NOT ignored. Participants must
# commit and push their completion JSONs — the trainer dashboard reads them from
# each participant's own fork. Ignoring them would show everyone as 0%.

# --- local vector stores (regenerated by the labs, large) ---
chroma_db/
**/chroma_db/
*.sqlite3

# --- editor / OS / tooling noise ---
.claude/
~$*
.DS_Store
Thumbs.db
.ipynb_checkpoints/
